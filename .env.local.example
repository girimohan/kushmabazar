# ──────────────────────────────────────────────────────────────
# KushmaBazar — Environment Variables
# Copy this file to .env.local and fill in your values.
# On Vercel: add these under Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────

# Airtable credentials
# Get from: https://airtable.com/account → API
AIRTABLE_API_KEY=your_airtable_personal_access_token_here

# Get from your base URL: https://airtable.com/appXXXXXXXXXXXXXX/...
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX

# The exact name of your Airtable table for form submissions
AIRTABLE_SUBMISSIONS_TABLE=Submissions

# The exact name of your Airtable table for published listings
AIRTABLE_LISTINGS_TABLE=Listings

# ──────────────────────────────────────────────────────────────
# Airtable "Listings" table — expected columns:
#   Title (text), Description (long text), Category (single select),
#   Location (text), Price (number), ContactName (text),
#   ContactPhone (text), ContactEmail (email),
#   ImageURL (url), Status (single select: "Approved" | "Pending")
#
# Airtable "Submissions" table — expected columns:
#   Title, Description, Category, Location, Price,
#   ContactName, ContactPhone, ContactEmail, Status (default "Pending")
# ──────────────────────────────────────────────────────────────
